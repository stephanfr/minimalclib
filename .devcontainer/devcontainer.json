{
    "name": "minimalclib",
    "build": {
        "dockerfile": "../Dockerfile.toolchain",
        "context": ".."
    },
    "remoteEnv": {
        "TOOLS": "/opt",
        "THIRD_PARTY": "/opt",
        "CPPUTEST_PATH": "/opt/cpputest"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.makefile-tools"
            ]
        }
    }
}
